#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
dot — thin wrapper around yadm

Usage:
  dot                       # show this help
  dot st                    # yadm status
  dot ls                    # list tracked files
  dot lse                   # list encrypted secrets
  dot diff                  # yadm diff (local vs last commit)
  dot review                # diff local files vs origin (GitHub)
  dot add FILE...           # stage specific files
  dot encrypt FILE...       # add FILE to encrypted secrets + re-cifrar
  dot skip FILE...          # ignore local changes (this machine only)
  dot unskip FILE...        # resume tracking changes
  dot com MESSAGE...        # commit with message
  dot amend                 # amend last commit
  dot pull                  # pull from origin
  dot push                  # push to origin
  dot sync [MESSAGE]        # add -u, commit, push
  dot bootstrap <user@host> # bootstrap dotfiles on a new machine

Notes:
- dot sync  stages only already-tracked files (safe, won't add new ones)
- dot add   stages a new file for tracking (public, goes into git)
- dot encrypt  adds a secret to the GPG-encrypted archive (never in git plain)
- secrets must remain untracked or in encrypt

New machine workflow:
  1. ssh-copy-id -i ~/.ssh/id_ed25519.pub user@newhost   # one-time with password
  2. dot bootstrap user@newhost                           # copies key + clones + GPG prompt

Workflows:
  New public file (first time):
    dot add ~/.bashrc && dot com "add bashrc" && dot push

  Edited a tracked file (day-to-day):
    dot sync                        # add + commit + push in one shot

  New secret file (first time):
    dot encrypt ~/.ssh/id_ed25519 && dot com "encrypt: id_ed25519" && dot push

  Secret file changed (e.g. rclone.conf updated):
    dot encrypt ~/.config/rclone/rclone.conf && dot com "encrypt: update rclone" && dot push

  Passphrase prompts on encrypt: normal — GPG re-encrypts the archive each time.
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  ""|-h|--help|help)
    usage
    ;;

  st|status)
    yadm status
    ;;

  ls)
    yadm ls-files
    ;;

  lse)
    echo "Encrypted secrets:"
    grep -v '^\s*$' "$HOME/.config/yadm/encrypt" | sed 's/^/  /'
    ;;

  diff)
    yadm diff
    ;;

  review)
    yadm fetch origin 2>/dev/null
    branch=$(yadm symbolic-ref --short HEAD 2>/dev/null || echo "master")
    if yadm diff "origin/$branch" --quiet 2>/dev/null; then
      echo "Local is in sync with origin/$branch."
    else
      yadm diff "origin/$branch"
    fi
    ;;

  add)
    [[ $# -gt 0 ]] || { echo "dot add: missing file(s)"; exit 2; }
    yadm add "$@"
    ;;

  encrypt)
    [[ $# -gt 0 ]] || { echo "dot encrypt: missing file(s)"; exit 2; }
    encrypt_file="$HOME/.config/yadm/encrypt"
    changed=0
    for f in "$@"; do
      # normalizar a path relativo desde $HOME (sin ~/ ni /home/user/)
      rel="${f/#$HOME\//}"
      rel="${rel/#\~\//}"
      if grep -qxF "$rel" "$encrypt_file" 2>/dev/null; then
        echo "Ya en encrypt: $rel"
      else
        echo "$rel" >> "$encrypt_file"
        echo "Agregado a encrypt: $rel"
        changed=1
      fi
    done
    echo "Cifrando..."
    yadm encrypt
    yadm add "$encrypt_file" "$HOME/.local/share/yadm/archive"
    echo ""
    echo "Listo. Commitea con:  dot com \"encrypt: descripcion\""
    ;;

  skip)
    [[ $# -gt 0 ]] || { echo "dot skip: missing file(s)"; exit 2; }
    yadm update-index --assume-unchanged "$@"
    ;;

  unskip)
    [[ $# -gt 0 ]] || { echo "dot unskip: missing file(s)"; exit 2; }
    yadm update-index --no-assume-unchanged "$@"
    ;;

  com|commit)
    [[ $# -gt 0 ]] || { echo "dot com: missing commit message"; exit 2; }
    yadm commit -m "$*"
    ;;

  amend)
    yadm commit --amend
    ;;

  pull)
    yadm pull
    ;;

  push)
    yadm push
    ;;

  sync)
    msg="${*:-sync: $(hostname) $(date +%F)}"
    yadm add -u
    if yadm diff --cached --quiet; then
      echo "Nothing to commit."
    else
      yadm commit -m "$msg"
      yadm push
    fi
    ;;

  bootstrap)
    [[ $# -gt 0 ]] || { echo "dot bootstrap: missing user@host"; exit 2; }
    target="$1"
    SSH_KEY="$HOME/.ssh/id_ed25519"
    DOTFILES_REPO="git@github.com:fsardi8/dotfiles.git"

    echo "→  Bootstrapping $target"

    # 1. Copy SSH private key so the new machine can auth to GitHub
    echo "→  Copying SSH key..."
    ssh "$target" "install -d -m 700 ~/.ssh"
    scp -q "$SSH_KEY" "$SSH_KEY.pub" "$target:~/.ssh/"
    ssh "$target" "chmod 600 ~/.ssh/id_ed25519"
    echo "✔  SSH key copied"

    # 2. Install yadm
    echo "→  Installing yadm..."
    ssh -t "$target" "
      if command -v apt-get &>/dev/null; then
        missing=()
        command -v yadm &>/dev/null || missing+=(yadm)
        command -v gpg  &>/dev/null || missing+=(gnupg)
        if [[ \${#missing[@]} -gt 0 ]]; then
          sudo apt-get update -q && sudo apt-get install -y -q \"\${missing[@]}\"
        fi
      elif command -v pacman &>/dev/null; then
        missing=()
        command -v yadm &>/dev/null || missing+=(yadm)
        command -v gpg  &>/dev/null || missing+=(gnupg)
        [[ \${#missing[@]} -gt 0 ]] && sudo pacman -S --noconfirm --needed \"\${missing[@]}\"
      else
        echo 'ERROR: unsupported package manager'; exit 1
      fi
    "
    echo "✔  yadm ready"

    # 3. Clone dotfiles (no-bootstrap so we can decrypt first)
    echo "→  Cloning dotfiles..."
    ssh "$target" "
      if ! yadm status &>/dev/null 2>&1; then
        ssh-keyscan github.com >> ~/.ssh/known_hosts 2>/dev/null
        yadm clone --no-bootstrap '$DOTFILES_REPO'
      else
        echo 'yadm already initialized, skipping clone'
      fi
    "
    echo "✔  Dotfiles cloned"

    # 4. NOPASSWD sudo — makes the rest of setup scriptable
    echo "→  Configuring NOPASSWD sudo..."
    REMOTE_USER=$(ssh "$target" "whoami")
    ssh -t "$target" "echo '${REMOTE_USER} ALL=(ALL) NOPASSWD:ALL' | sudo tee /etc/sudoers.d/90-nopasswd > /dev/null && sudo chmod 440 /etc/sudoers.d/90-nopasswd"
    echo "✔  NOPASSWD sudo configured for ${REMOTE_USER}"

    # 5. Decrypt secrets (GPG — interactive, user must paste key from Bitwarden)
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  GPG key needed to decrypt secrets (SSH keys, rclone, etc.)"
    echo "  Open Bitwarden → 'GPG private key - fsardi8'"
    echo "  Copy the full block (BEGIN/END lines included)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    ssh -t "$target" "
      set -e
      tmpf=\$(mktemp)
      echo 'Paste GPG key then press Ctrl+D:'
      cat > \"\$tmpf\"
      gpg --import \"\$tmpf\"
      rm -f \"\$tmpf\"
      GPG_KEY_ID=A28F843C63852BF6
      echo \"\${GPG_KEY_ID}:6:\" | gpg --import-ownertrust
      yadm decrypt
      chmod 600 ~/.ssh/id_ed25519 ~/.ssh/id_rsa 2>/dev/null || true
    "
    echo "✔  Secrets decrypted"

    # 6. Run yadm bootstrap
    echo "→  Running yadm bootstrap..."
    ssh -t "$target" "yadm bootstrap"
    echo ""
    echo "✔  $target is ready. SSH in with: ssh $target"
    ;;

  *)
    echo "Unknown command: $cmd"
    usage
    exit 2
    ;;
esac
