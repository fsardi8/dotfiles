#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
dot — thin wrapper around yadm

Usage:
  dot                 # show this help
  dot st              # yadm status
  dot ls              # list tracked files
  dot diff            # yadm diff
  dot add FILE...     # stage specific files
  dot skip FILE...    # ignore local changes (this machine only)
  dot unskip FILE...  # resume tracking changes
  dot com MESSAGE...  # commit with message
  dot amend           # amend last commit
  dot pull            # pull from origin
  dot push            # push to origin
  dot sync [MESSAGE]  # add -u, commit, push

Notes:
- dot sync stages only tracked files (safe)
- secrets must remain untracked
EOF
}

cmd="${1:-}"
shift || true

case "$cmd" in
  ""|-h|--help|help)
    usage
    ;;

  st|status)
    yadm status
    ;;

  ls)
    yadm ls-files
    ;;

  diff)
    yadm diff
    ;;

  add)
    [[ $# -gt 0 ]] || { echo "dot add: missing file(s)"; exit 2; }
    yadm add "$@"
    ;;

  skip)
    [[ $# -gt 0 ]] || { echo "dot skip: missing file(s)"; exit 2; }
    yadm update-index --assume-unchanged "$@"
    ;;

  unskip)
    [[ $# -gt 0 ]] || { echo "dot unskip: missing file(s)"; exit 2; }
    yadm update-index --no-assume-unchanged "$@"
    ;;

  com|commit)
    [[ $# -gt 0 ]] || { echo "dot com: missing commit message"; exit 2; }
    yadm commit -m "$*"
    ;;

  amend)
    yadm commit --amend
    ;;

  pull)
    yadm pull
    ;;

  push)
    yadm push
    ;;

  sync)
    msg="${*:-sync: $(hostname) $(date +%F)}"
    yadm add -u
    if yadm diff --cached --quiet; then
      echo "Nothing to commit."
    else
      yadm commit -m "$msg"
      yadm push
    fi
    ;;

  *)
    echo "Unknown command: $cmd"
    usage
    exit 2
    ;;
esac
